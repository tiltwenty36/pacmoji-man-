<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pacmoji Man - Emoji Pac-Man Game</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
            font-family: 'Arial', sans-serif;
            color: #eee;
        }

        .game-container {
            text-align: center;
            background: rgba(0, 0, 0, 0.5);
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.7);
            border: 3px solid #00d4ff;
        }

        h1 {
            font-size: 2.5em;
            margin-bottom: 20px;
            color: #00d4ff;
            text-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
            font-style: italic;
        }

        .stats {
            display: flex;
            justify-content: space-around;
            margin-bottom: 20px;
            padding: 15px;
            background: rgba(0, 212, 255, 0.1);
            border-radius: 10px;
            border: 2px solid #00d4ff;
        }

        .stat {
            font-size: 1.2em;
            font-weight: bold;
        }

        .stat-label {
            color: #00d4ff;
            display: block;
            font-size: 0.8em;
            margin-bottom: 5px;
        }

        .stat-value {
            color: #fff;
            font-size: 1.5em;
        }

        #gameBoard {
            display: inline-grid;
            grid-template-columns: repeat(21, 30px);
            grid-template-rows: repeat(21, 30px);
            gap: 1px;
            background: #000;
            padding: 10px;
            border: 3px solid #00d4ff;
            margin: 20px 0;
            border-radius: 5px;
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
        }

        .cell {
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #1a1a1a;
            font-size: 24px;
            position: relative;
        }

        .cell.wall {
            background: #00d4ff;
            box-shadow: inset 0 0 3px rgba(0, 212, 255, 0.5);
        }

        .cell.dot {
            background: #1a1a1a;
        }

        .dot-graphic {
            width: 4px;
            height: 4px;
            background: #ffff00;
            border-radius: 50%;
            box-shadow: 0 0 2px #ffff00;
        }

        .controls {
            margin: 20px 0;
            padding: 15px;
            background: rgba(0, 212, 255, 0.1);
            border-radius: 10px;
            border: 2px solid #00d4ff;
        }

        .controls p {
            font-size: 0.9em;
            margin-bottom: 10px;
            color: #aaa;
        }

        .button-group {
            display: flex;
            gap: 10px;
            justify-content: center;
            flex-wrap: wrap;
        }

        button {
            padding: 12px 24px;
            font-size: 1em;
            font-weight: bold;
            background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
            color: #000;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(0, 212, 255, 0.3);
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 212, 255, 0.5);
            background: linear-gradient(135deg, #00ffff 0%, #00ccff 100%);
        }

        button:active {
            transform: translateY(0);
        }

        .game-message {
            font-size: 2em;
            font-weight: bold;
            margin: 20px 0;
            text-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
            min-height: 40px;
        }

        .win-message {
            color: #00ff00;
            text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
        }

        .lose-message {
            color: #ff0000;
            text-shadow: 0 0 10px rgba(255, 0, 0, 0.5);
        }

        .instructions {
            margin-top: 20px;
            padding: 15px;
            background: rgba(0, 212, 255, 0.05);
            border-left: 4px solid #00d4ff;
            text-align: left;
            font-size: 0.85em;
            color: #aaa;
            border-radius: 5px;
        }

        .instructions h3 {
            color: #00d4ff;
            margin-bottom: 10px;
        }

        .instructions ul {
            margin-left: 20px;
            line-height: 1.6;
        }

        @media (max-width: 800px) {
            #gameBoard {
                grid-template-columns: repeat(21, 25px);
                grid-template-rows: repeat(21, 25px);
            }

            .cell {
                width: 25px;
                height: 25px;
                font-size: 18px;
            }

            h1 {
                font-size: 1.8em;
            }

            .game-container {
                padding: 20px;
                margin: 10px;
            }
        }
    </style>
</head>
<body>
    <div class="game-container">
        <h1>🎮 Pacmoji Man 🎮</h1>
        
        <div class="stats">
            <div class="stat">
                <span class="stat-label">SCORE</span>
                <span class="stat-value" id="score">0</span>
            </div>
            <div class="stat">
                <span class="stat-label">LEVEL</span>
                <span class="stat-value" id="level">1</span>
            </div>
            <div class="stat">
                <span class="stat-label">LIVES</span>
                <span class="stat-value" id="lives">3</span>
            </div>
        </div>

        <div id="gameBoard"></div>

        <div class="game-message" id="gameMessage"></div>

        <div class="controls">
            <p>🎮 Use ARROW KEYS or WASD to move</p>
            <div class="button-group">
                <button onclick="game.startGame()">Start Game</button>
                <button onclick="game.pauseGame()">Pause</button>
                <button onclick="game.resetGame()">Reset</button>
            </div>
        </div>

        <div class="instructions">
            <h3>📖 How to Play</h3>
            <ul>
                <li>🍎 You are the Apple - collect all the dots to win</li>
                <li>👻 Avoid the 4 enemy emojis (Ghost, Vampire, Alien, Pumpkin)</li>
                <li>⭐ Eating a dot = +10 points</li>
                <li>😱 Hit by enemy = lose 1 life</li>
                <li>🏁 Clear the board to advance to the next level</li>
                <li>👾 Win all 3 levels to beat the game!</li>
            </ul>
        </div>
    </div>

    <script>
        const GRID_WIDTH = 21;
        const GRID_HEIGHT = 21;
        const WALL = '#';
        const EMPTY = ' ';
        const DOT = '.';
        const PLAYER = 'P';
        const ENEMY = 'E';

        const EMOJIS = {
            player: '🍎',
            enemies: ['👻', '🧛', '👽', '🎃'],
            dot: '⭐'
        };

        const DIRECTIONS = {
            UP: { x: 0, y: -1 },
            DOWN: { x: 0, y: 1 },
            LEFT: { x: -1, y: 0 },
            RIGHT: { x: 1, y: 0 },
            NONE: { x: 0, y: 0 }
        };

        class Game {
            constructor() {
                this.level = 1;
                this.score = 0;
                this.lives = 3;
                this.gameActive = false;
                this.gamePaused = false;
                this.playerPos = { x: 10, y: 10 };
                this.playerDirection = DIRECTIONS.NONE;
                this.nextDirection = DIRECTIONS.NONE;
                this.enemies = [];
                this.maze = [];
                this.dotsRemaining = 0;
                this.gameLoopInterval = null;
                this.enemyMoveInterval = null;

                this.setupEventListeners();
                this.initializeMaze();
                this.renderBoard();
            }

            setupEventListeners() {
                document.addEventListener('keydown', (e) => this.handleKeyDown(e));
                document.addEventListener('keyup', (e) => this.handleKeyUp(e));
            }

            handleKeyDown(e) {
                const key = e.key.toLowerCase();
                const arrowMap = {
                    'arrowup': DIRECTIONS.UP,
                    'arrowdown': DIRECTIONS.DOWN,
                    'arrowleft': DIRECTIONS.LEFT,
                    'arrowright': DIRECTIONS.RIGHT,
                    'w': DIRECTIONS.UP,
                    's': DIRECTIONS.DOWN,
                    'a': DIRECTIONS.LEFT,
                    'd': DIRECTIONS.RIGHT
                };

                if (arrowMap[key]) {
                    e.preventDefault();
                    this.nextDirection = arrowMap[key];
                }
            }

            handleKeyUp(e) {
                const key = e.key.toLowerCase();
                if (['arrowup', 'arrowdown', 'arrowleft', 'arrowright', 'w', 's', 'a', 'd'].includes(key)) {
                    this.nextDirection = DIRECTIONS.NONE;
                }
            }

            initializeMaze() {
                const mazeLayout = [
                    "###################",
                    "#.................#",
                    "#.###.#####.###.#.#",
                    "#.#...#.....#...#.#",
                    "#.#.###.###.#.###.#",
                    "#...#.......#.....#",
                    "###.#.#####.#.###.#",
                    "#.....#.....#.....#",
                    "#.#####.###.#####.#",
                    "#.................#",
                    "#.#####.###.#####.#",
                    "#.....#.....#.....#",
                    "###.#.#####.#.###.#",
                    "#...#.......#.....#",
                    "#.#.###.###.#.###.#",
                    "#.#...#.....#...#.#",
                    "#.###.#####.###.#.#",
                    "#.................#",
                    "###################"
                ];

                this.maze = mazeLayout.map(row => row.split(''));
                this.dotsRemaining = this.countDots();
                this.setupEnemies();
            }

            setupEnemies() {
                const enemyStartPositions = [
                    { x: 9, y: 8 },
                    { x: 10, y: 8 },
                    { x: 11, y: 8 },
                    { x: 10, y: 9 }
                ];

                this.enemies = enemyStartPositions.slice(0, Math.min(3 + this.level, 4)).map((pos, idx) => ({
                    x: pos.x,
                    y: pos.y,
                    emoji: EMOJIS.enemies[idx % EMOJIS.enemies.length],
                    moveCounter: 0,
                    direction: DIRECTIONS.NONE
                }));
            }

            countDots() {
                let count = 0;
                for (let row of this.maze) {
                    for (let cell of row) {
                        if (cell === DOT) count++;
                    }
                }
                return count;
            }

            startGame() {
                if (this.gameActive) return;
                this.gameActive = true;
                this.gamePaused = false;
                this.updateMessage('');

                if (this.gameLoopInterval) clearInterval(this.gameLoopInterval);
                if (this.enemyMoveInterval) clearInterval(this.enemyMoveInterval);

                this.gameLoopInterval = setInterval(() => this.update(), 150);
                this.enemyMoveInterval = setInterval(() => this.updateEnemies(), 300);
            }

            pauseGame() {
                if (!this.gameActive) return;
                this.gamePaused = !this.gamePaused;
                this.updateMessage(this.gamePaused ? '⏸️ PAUSED' : '');
                
                if (this.gamePaused) {
                    clearInterval(this.gameLoopInterval);
                    clearInterval(this.enemyMoveInterval);
                } else {
                    this.gameLoopInterval = setInterval(() => this.update(), 150);
                    this.enemyMoveInterval = setInterval(() => this.updateEnemies(), 300);
                }
            }

            resetGame() {
                clearInterval(this.gameLoopInterval);
                clearInterval(this.enemyMoveInterval);
                this.level = 1;
                this.score = 0;
                this.lives = 3;
                this.gameActive = false;
                this.gamePaused = false;
                this.playerPos = { x: 10, y: 10 };
                this.playerDirection = DIRECTIONS.NONE;
                this.nextDirection = DIRECTIONS.NONE;
                this.initializeMaze();
                this.updateUI();
                this.renderBoard();
                this.updateMessage('');
            }

            update() {
                if (!this.gameActive || this.gamePaused) return;

                // Try to move in the next direction
                const nextPos = {
                    x: this.playerPos.x + this.nextDirection.x,
                    y: this.playerPos.y + this.nextDirection.y
                };

                if (this.isValidMove(nextPos)) {
                    this.playerPos = nextPos;
                    this.playerDirection = this.nextDirection;
                } else {
                    // Try to continue in the current direction
                    const currentNextPos = {
                        x: this.playerPos.x + this.playerDirection.x,
                        y: this.playerPos.y + this.playerDirection.y
                    };
                    if (this.isValidMove(currentNextPos)) {
                        this.playerPos = currentNextPos;
                    }
                }

                // Collect dots
                if (this.maze[this.playerPos.y][this.playerPos.x] === DOT) {
                    this.maze[this.playerPos.y][this.playerPos.x] = EMPTY;
                    this.score += 10;
                    this.dotsRemaining--;

                    if (this.dotsRemaining === 0) {
                        this.levelUp();
                        return;
                    }
                }

                // Check collisions with enemies
                this.checkEnemyCollision();
                this.updateUI();
                this.renderBoard();
            }

            updateEnemies() {
                if (!this.gameActive || this.gamePaused) return;

                for (let enemy of this.enemies) {
                    enemy.moveCounter++;

                    if (enemy.moveCounter % 2 === 0) {
                        const directions = [DIRECTIONS.UP, DIRECTIONS.DOWN, DIRECTIONS.LEFT, DIRECTIONS.RIGHT];
                        let validDirections = [];

                        for (let dir of directions) {
                            const newPos = {
                                x: enemy.x + dir.x,
                                y: enemy.y + dir.y
                            };
                            if (this.isValidMove(newPos)) {
                                validDirections.push(dir);
                            }
                        }

                        if (validDirections.length > 0) {
                            const randomDir = validDirections[Math.floor(Math.random() * validDirections.length)];
                            enemy.x += randomDir.x;
                            enemy.y += randomDir.y;
                        }
                    }
                }

                this.checkEnemyCollision();
                this.renderBoard();
            }

            isValidMove(pos) {
                if (pos.x < 0 || pos.x >= GRID_WIDTH || pos.y < 0 || pos.y >= GRID_HEIGHT) {
                    return false;
                }
                return this.maze[pos.y][pos.x] !== WALL;
            }

            checkEnemyCollision() {
                for (let enemy of this.enemies) {
                    if (this.playerPos.x === enemy.x && this.playerPos.y === enemy.y) {
                        this.lives--;
                        if (this.lives <= 0) {
                            this.gameOver();
                        } else {
                            this.resetPlayerPosition();
                        }
                        return;
                    }
                }
            }

            resetPlayerPosition() {
                this.playerPos = { x: 10, y: 10 };
            }

            levelUp() {
                this.level++;
                if (this.level > 3) {
                    this.winGame();
                } else {
                    this.score += 100;
                    this.gameActive = false;
                    this.updateMessage(`🎉 LEVEL ${this.level}! Press Start Game`);
                    this.initializeMaze();
                    this.updateUI();
                    this.renderBoard();
                }
            }

            gameOver() {
                this.gameActive = false;
                clearInterval(this.gameLoopInterval);
                clearInterval(this.enemyMoveInterval);
                this.updateMessage('💀 GAME OVER - Press Reset');
            }

            winGame() {
                this.gameActive = false;
                clearInterval(this.gameLoopInterval);
                clearInterval(this.enemyMoveInterval);
                this.updateMessage('🏆 YOU WIN! BEAT ALL 3 LEVELS!');
            }

            updateUI() {
                document.getElementById('score').textContent = this.score;
                document.getElementById('level').textContent = this.level;
                document.getElementById('lives').textContent = this.lives;
            }

            updateMessage(msg) {
                const messageEl = document.getElementById('gameMessage');
                messageEl.textContent = msg;
                messageEl.classList.remove('win-message', 'lose-message');
                if (msg.includes('WIN')) messageEl.classList.add('win-message');
                if (msg.includes('GAME OVER')) messageEl.classList.add('lose-message');
            }

            renderBoard() {
                const board = document.getElementById('gameBoard');
                board.innerHTML = '';

                for (let y = 0; y < GRID_HEIGHT; y++) {
                    for (let x = 0; x < GRID_WIDTH; x++) {
                        const cell = document.createElement('div');
                        cell.className = 'cell';

                        // Player
                        if (this.playerPos.x === x && this.playerPos.y === y) {
                            cell.textContent = EMOJIS.player;
                        }
                        // Enemies
                        else if (this.enemies.some(e => e.x === x && e.y === y)) {
                            const enemy = this.enemies.find(e => e.x === x && e.y === y);
                            cell.textContent = enemy.emoji;
                        }
                        // Walls
                        else if (this.maze[y][x] === WALL) {
                            cell.classList.add('wall');
                        }
                        // Dots
                        else if (this.maze[y][x] === DOT) {
                            cell.classList.add('dot');
                            cell.appendChild(this.createDotElement());
                        }

                        board.appendChild(cell);
                    }
                }
            }

            createDotElement() {
                const dot = document.createElement('div');
                dot.className = 'dot-graphic';
                return dot;
            }
        }

        // Initialize and start the game
        const game = new Game();
    </script>
</body>
</html>
